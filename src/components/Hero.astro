---
import { techIcons } from "@data/icons";

type Props = {
  name: string;
  role: string;
  heroTagline: string;
  heroSummary: string;
  githubUrl: string;
  email: string;
};

const { name, role, heroTagline, heroSummary, githubUrl, email } = Astro.props;
---

<section id="inicio" class="section home">
  <div class="container hero-grid">
    <div class="hero-left reveal">
      <div class="profile-area">
        <span class="text-mono text-accent mb-1">Senior Architect</span>
        <h1 class="name">{name}</h1>
        <div class="role-container">
          <p class="role-text">{role}</p>
          <div class="location">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-mono text-smoke">Santiago, Chile</span>
          </div>
        </div>
      </div>

      <div class="about-content">
        <h2 class="about-title">Sobre mí</h2>
        <p class="about-text text-smoke">{heroSummary}</p>
        
        <div class="social-links">
          <a href={githubUrl} target="_blank" class="social-link glass-card" aria-label="GitHub Profile">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            <span>GitHub</span>
          </a>
          <a href={`mailto:${email}`} class="social-link glass-card" aria-label="Send Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span>Email</span>
          </a>
        </div>
      </div>
    </div>

    <div class="hero-right reveal reveal-delay-2">
      <div class="visual-element glass-card">
        <div class="terminal-header">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="text-mono title">status.sys</span>
        </div>
        <div class="terminal-body text-mono">
          <p><span class="text-accent">></span> system.init()</p>
          <p><span class="text-smoke">Loading core architectures...</span></p>
          <p><span class="text-accent">></span> stack.analyze()</p>
          <ul class="terminal-list">
            <li>FASTAPI: <span class="text-accent">Active</span></li>
            <li>ANGULAR: <span class="text-accent">Active</span></li>
            <li>POSTGRES: <span class="text-accent">Synced</span></li>
          </ul>
          <p><span class="text-accent">></span> status: <span class="ready-text">READY</span></p>
          <span class="cursor">_</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .home {
    padding-top: 10rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: start;
  }

  .name {
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .role-container {
    margin-bottom: 4rem;
  }

  .role-text {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }

  .about-title {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .about-text {
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 40rem;
    margin-bottom: 2rem;
    text-wrap: pretty;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
  }

  .visual-element {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .terminal-header {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--line);
  }

  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .red { background: #ff5f56; }
  .yellow { background: #ffbd2e; }
  .green { background: #27c93f; }
  .terminal-header .title { font-size: 0.65rem; margin-left: 0.5rem; opacity: 0.5; }

  .terminal-body {
    padding: 2rem;
    font-size: 0.9rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .terminal-list {
    margin: 0.5rem 0;
    padding-left: 1.5rem;
    list-style: none;
  }

  .ready-text {
    color: #27c93f;
    font-weight: 800;
  }

  .cursor {
    animation: blink 1s infinite;
    color: var(--accent);
  }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .mb-1 { display: block; margin-bottom: 1rem; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 6rem; }
    .hero-right { order: -1; }
    .visual-element { aspect-ratio: 16/9; }
  }
</style>
