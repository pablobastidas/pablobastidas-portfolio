---
import { experiences } from "@data/experience";
---

<section class="section" id="trayectoria">
  <div class="container">
    <div class="header-area mb-4">
      <span class="text-mono text-accent">/Experience</span>
      <h2 class="section-title">Trayectoria Profesional</h2>
    </div>

    <div class="timeline-container">
      {
        experiences.map((block, index) => (
          <div class={`timeline-item reveal reveal-delay-${(index % 3) + 1}`}>
            <div class="timeline-marker">
              <div class="marker-dot"></div>
              <div class="marker-line"></div>
            </div>
            
            <div class="timeline-content glass-card">
              <div class="content-header">
                <div class="title-area">
                  <span class="year text-mono">{block.year}</span>
                  <h3 class="title">{block.title}</h3>
                  <p class="company text-accent text-mono">{block.company}</p>
                </div>
              </div>
              <p class="description text-smoke">{block.description}</p>
              <div class="tag-list">
                {block.tags.map(tag => (
                  <span class="tag text-mono">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline-container {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    padding: 2rem 0;
  }

  .timeline-item {
    display: flex;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .marker-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 15px var(--accent);
    z-index: 2;
    transition: transform 0.3s ease;
  }

  .marker-line {
    width: 1px;
    flex-grow: 1;
    background: linear-gradient(to bottom, var(--accent) 0%, var(--line) 30%, var(--line) 100%);
    opacity: 0.3;
  }

  .timeline-item:last-child .marker-line {
    display: none;
  }

  .timeline-content {
    padding: 2rem;
    flex-grow: 1;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .timeline-item:hover .timeline-content {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
    transform: translateX(10px);
  }

  .timeline-item:hover .marker-dot {
    transform: scale(1.5);
  }

  .content-header {
    margin-bottom: 1.5rem;
  }

  .title-area {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .company {
    font-size: 0.65rem;
    margin: 0;
    opacity: 0.9;
  }

  .year {
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    width: fit-content;
  }

  .title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  .description {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .tag-list {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.6rem;
    color: var(--text-smoke);
    border: 1px solid var(--line);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .timeline-item:hover .tag {
    border-color: var(--accent-muted);
    color: var(--text);
  }

  @media (max-width: 640px) {
    .timeline-item {
      gap: 1.5rem;
    }
    
    .timeline-content {
      padding: 1.5rem;
    }

    .content-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .year {
      order: -1;
    }
  }
</style>
