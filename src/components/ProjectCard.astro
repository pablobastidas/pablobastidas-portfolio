---
import type { Project } from "@data/projects";

type Props = {
  project: Project;
  colorClass?: string;
};

const { project, colorClass = "" } = Astro.props;
---

<article class={`proyect glass-card ${colorClass}`}>
  <a href={project.links[0]?.href} target="_blank" rel="noopener noreferrer" class="proyect__link">
    <div class="proyect__header">
      <div class="proyect__title">
        <span>{project.name}</span>
      </div>
    </div>

    <div class="proyect__content">
      <p class="smoke">{project.summary}</p>
      <ul class="chips">
        {project.tech.slice(0, 3).map((tech) => (
          <li class="chip text-mono">{tech}</li>
        ))}
      </ul>
    </div>

    <div class="proyect__footer">
      <span class="text-mono text-accent">{project.status}</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="icon-arrow">
        <line x1="5" y1="12" x2="19" y2="12" class="line"></line>
        <polyline points="12 5 19 12 12 19" class="arrow"></polyline>
      </svg>
    </div>
  </a>
</article>

<style>
  .proyect {
    position: relative;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
    width: 100%; /* Asegura que ocupe todo el espacio del flex-item */
    display: flex;
  }

  .proyect:hover {
    background-color: rgba(255, 255, 255, 0.05);
    transform: translateY(-4px);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
    border-color: var(--accent);
  }

  .proyect::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(
      600px circle at var(--mouse-x) var(--mouse-y),
      var(--accent-muted),
      transparent 40%
    );
    z-index: -1;
  }

  .proyect:hover::after {
    opacity: 1;
  }

  .proyect__link {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    padding: 2rem; /* Aumentado para mejor aire */
    gap: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .proyect__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .proyect__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .proyect__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-grow: 1;
  }

  .smoke {
    color: var(--text-smoke);
    font-size: 0.95rem;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .chip {
    font-size: 0.65rem;
    color: var(--text-smoke);
    border: 1px solid var(--line);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .proyect__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .icon-arrow {
    color: var(--accent);
    transition: transform 0.3s ease;
  }

  .line {
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    stroke: var(--accent);
  }

  .arrow {
    transition: transform 0.3s ease;
    stroke: var(--accent);
  }

  .proyect:hover .line {
    transform: scaleX(1);
  }

  .proyect:hover .arrow {
    transform: translateX(2px);
  }
</style>
