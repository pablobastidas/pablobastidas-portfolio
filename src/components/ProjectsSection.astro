---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "@data/projects";

const colors = ["", "color-emerald", "color-amber", "color-violet"];
---

<section class="section proyects-wrapper reveal" id="proyectos">
  <div class="container">
    <div class="header-area mb-4">
      <div class="header-content">
        <div>
          <span class="text-mono text-accent">/Work</span>
          <h2 class="section-title">Proyectos Destacados</h2>
        </div>
        <div class="carousel-nav">
          <button id="prev-btn" class="nav-btn glass-card" aria-label="Anterior">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button id="next-btn" class="nav-btn glass-card" aria-label="Siguiente">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="proyects__list-container">
      <div class="proyects__list">
        {projects.filter(p => p.featured).map((pro, index) => (
          <ProjectCard project={pro} colorClass={colors[index % colors.length]} />
        ))}
      </div>
    </div>

    <a href="#contacto" class="proyects__more text-mono">¿Tienes un reto para mí? Hablemos . . .</a>
  </div>
</section>

<script>
  // Spotlight logic
  const wrapper = document.querySelector('.proyects__list');
  const cards = document.querySelectorAll('.proyect');

  wrapper?.addEventListener('mousemove', (e) => {
    cards.forEach((card) => {
      const rect = card.getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left;
      const y = (e as MouseEvent).clientY - rect.top;
      (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
      (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
    });
  });

  // Carousel logic
  const list = document.querySelector('.proyects__list');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  if (list && prevBtn && nextBtn) {
    const scrollAmount = 350;

    nextBtn.addEventListener('click', () => {
      list.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });

    prevBtn.addEventListener('click', () => {
      list.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    // Toggle button visibility based on scroll
    const updateButtons = () => {
      const isAtStart = list.scrollLeft <= 5;
      const isAtEnd = list.scrollLeft + list.clientWidth >= list.scrollWidth - 5;
      
      (prevBtn as HTMLElement).style.opacity = isAtStart ? '0.2' : '1';
      (prevBtn as HTMLElement).style.pointerEvents = isAtStart ? 'none' : 'auto';
      (nextBtn as HTMLElement).style.opacity = isAtEnd ? '0.2' : '1';
      (nextBtn as HTMLElement).style.pointerEvents = isAtEnd ? 'none' : 'auto';
    };

    list.addEventListener('scroll', updateButtons);
    window.addEventListener('resize', updateButtons);
    updateButtons(); // Initial check
  }
</script>

<style>
  .proyects-wrapper {
    margin-bottom: 8rem;
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
  }

  .carousel-nav {
    display: flex;
    gap: 0.75rem;
  }

  .nav-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 50%;
    color: var(--text);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.03);
    pointer-events: auto;
  }

  .nav-btn:hover {
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.08);
    transform: scale(1.1);
  }

  .proyects__list-container {
    position: relative;
    margin: 0 -1rem; /* Margen negativo para permitir que el scroll llegue al borde */
    padding: 0 1rem;
  }

  .proyects__list {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 2rem 1rem 4rem 1rem; /* Padding extra para luces y sombras */
    margin: 0;
    -ms-overflow-style: none;
    scrollbar-width: none;
    align-items: stretch;
  }

  .proyects__list::-webkit-scrollbar {
    display: none;
  }

  /* Force cards to have a consistent width in carousel */
  .proyects__list > :global(*) {
    flex: 0 0 calc(33.333% - 1rem); /* Ajustado para que quepan 3 o se vea la 3ra con aire */
    min-width: 320px;
    scroll-snap-align: center; /* Alineación al centro para mejor visibilidad */
    display: flex;
  }

  .proyects__more {
    display: inline-block;
    margin-top: 1rem;
    color: var(--text-smoke);
    text-decoration: none;
    transition: color 0.2s;
    font-size: 0.9rem;
  }

  .proyects__more:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .proyects__list > :global(*) {
      flex: 0 0 85vw;
    }
    
    .header-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }
</style>
